#!/usr/bin/env python3
"""
Dual-Storage Distribution Script v3.1
- Scans project for resources, excluding scripts and config files.
- Uploads large files to HuggingFace (${HF_USERNAME}/${HF_REPO_NAME}) with retry logic.
- Sync Deletion: Cleans up redundant files on HF that are deleted locally.
- Full Manifest Generation: Creates a comprehensive index for the frontend.
- Robust Logging: Writes activity to distribute.log.
"""
import os
import sys
import json
import logging
import time
import subprocess
from pathlib import Path
from datetime import datetime
from functools import wraps

# --- Configuration ---
SIZE_THRESHOLD = 50 * 1024 * 1024  # 50MB
HF_REPO_ID = "${HF_USERNAME}/${HF_REPO_NAME}"
PROJECT_ROOT = Path(__file__).resolve().parent.parent

# Exclude directories (strictly for scanning)
EXCLUDE_DIRS = {'.git', '.idea', '.vscode', 'venv', 'node_modules', '__pycache__', '.github', 'scripts', 'data'}

# Logging setup
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s [%(levelname)s] %(message)s',
    handlers=[
        logging.FileHandler(PROJECT_ROOT / "distribute.log", encoding='utf-8'),
        logging.StreamHandler()
    ]
)
logger = logging.getLogger(__name__)

def retry(exceptions, tries=3, delay=2, backoff=2):
    def decorator(f):
        @wraps(f)
        def wrapper(*args, **kwargs):
            mtries, mdelay = tries, delay
            while mtries > 1:
                try:
                    return f(*args, **kwargs)
                except exceptions as e:
                    logger.warning(f"Error: {e}, Retrying in {mdelay}s...")
                    time.sleep(mdelay)
                    mtries -= 1
                    mdelay *= backoff
            return f(*args, **kwargs)
        return wrapper
    return decorator

def get_file_info(path):
    stat = path.stat()
    return {
        "size": stat.st_size,
        "mtime": datetime.fromtimestamp(stat.st_mtime).strftime("%Y-%m-%d %H:%M:%S")
    }

def run_git_cmd(args):
    try:
        subprocess.run(['git'] + args, cwd=PROJECT_ROOT, check=False, capture_output=True)
    except Exception as e:
        logger.debug(f"Git command failed: {args} - {e}")

def scan_files():
    large_files = []
    small_files = []
    logger.info(f"Scanning files (Threshold: {SIZE_THRESHOLD/1024/1024:.0f}MB)...")

    for path in PROJECT_ROOT.rglob('*'):
        if not path.is_file(): continue
        parts = path.relative_to(PROJECT_ROOT).parts
        
        # Strict resource filtering
        if any(p.startswith('.') for p in parts): continue
        if any(ex in parts for ex in EXCLUDE_DIRS): continue
        if path.name in ['index.html', 'README.md', 'setup.bat', 'setup.sh', 'distribute.log', '.gitignore', '.gitattributes']: continue

        try:
            info = get_file_info(path)
            if info["size"] >= SIZE_THRESHOLD:
                large_files.append(path)
            else:
                small_files.append(path)
        except OSError: pass

    return large_files, small_files

@retry(Exception, tries=3)
def upload_file_to_hf(api, file_path):
    rel_path = file_path.relative_to(PROJECT_ROOT).as_posix()
    api.upload_file(
        path_or_fileobj=str(file_path),
        path_in_repo=rel_path,
        repo_id=HF_REPO_ID,
        repo_type="dataset",
        commit_message=f"Upload: {os.path.basename(rel_path)}"
    )

def upload_to_hf(files):
    if not files: return
    logger.info(f"Uploading {len(files)} files to HuggingFace...")
    try:
        from huggingface_hub import HfApi
        api = HfApi()
        for f in files:
            upload_file_to_hf(api, f)
    except Exception as e:
        logger.error(f"HF Upload failed: {e}")

def sync_hf_deletions(local_large_files):
    logger.info("Checking for redundant files on HuggingFace...")
    try:
        from huggingface_hub import HfApi, list_repo_files
        api = HfApi()
        remote_files = list_repo_files(repo_id=HF_REPO_ID, repo_type="dataset")
        local_rel_paths = {f.relative_to(PROJECT_ROOT).as_posix() for f in local_large_files}

        to_delete = [rf for rf in remote_files if rf not in local_rel_paths and not rf.endswith(('.gitattributes', 'README.md', '.gitignore'))]

        if to_delete:
            for rf in to_delete:
                api.delete_file(path_in_repo=rf, repo_id=HF_REPO_ID, repo_type="dataset")
            logger.info(f"Deleted {len(to_delete)} files from HF")
    except Exception as e:
        logger.warning(f"Sync deletion failed: {e}")

def update_gitignore(large_files):
    gitignore_path = PROJECT_ROOT / '.gitignore'
    rules = [f.relative_to(PROJECT_ROOT).as_posix() for f in large_files]
    # Simple overwrite for clarity in this version
    with open(gitignore_path, 'a+', encoding='utf-8') as f:
        f.write("\n# [Auto-Managed Large Files]\n")
        for r in sorted(rules):
            f.write(f"{r}\n")
            run_git_cmd(['rm', '--cached', r])

def generate_manifest(large_files, small_files):
    logger.info("Generating full manifest (data/file_manifest.json)...")
    manifest = {
        "hf_repo_id": HF_REPO_ID,
        "updated_at": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        "files": []
    }

    # Add Large Files (HF)
    for f in large_files:
        info = get_file_info(f)
        rel_path = f.relative_to(PROJECT_ROOT).as_posix()
        manifest["files"].append({
            "name": f.name, "path": rel_path, "extension": f.suffix.lstrip('.').lower(),
            "size_mb": round(info["size"] / 1024 / 1024, 2), "is_hf": True,
            "url": f"https://huggingface.co/datasets/{HF_REPO_ID}/resolve/main/{rel_path}",
            "last_modified": info["mtime"]
        })

    # Add Small Files (GitHub)
    github_raw_base = f"https://raw.githubusercontent.com/${GITHUB_USERNAME}/${GITHUB_REPO_NAME}/main"
    for f in small_files:
        info = get_file_info(f)
        rel_path = f.relative_to(PROJECT_ROOT).as_posix()
        manifest["files"].append({
            "name": f.name, "path": rel_path, "extension": f.suffix.lstrip('.').lower(),
            "size_mb": round(info["size"] / 1024 / 1024, 2), "is_hf": False,
            "url": f"{github_raw_base}/{rel_path}", "last_modified": info["mtime"]
        })

    (PROJECT_ROOT / 'data').mkdir(exist_ok=True)
    with open(PROJECT_ROOT / 'data' / 'file_manifest.json', 'w', encoding='utf-8') as f:
        json.dump(manifest, f, ensure_ascii=False, indent=2)

def main():
    start_time = time.time()
    large, small = scan_files()
    logger.info(f"Stats: {len(large)} large, {len(small)} small files")
    
    upload_to_hf(large)
    sync_hf_deletions(large)
    update_gitignore(large)
    generate_manifest(large, small)
    
    logger.info(f"Done in {time.time() - start_time:.1f}s")

if __name__ == "__main__":
    main()
